<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>PerTe</title>
<meta name="theme-color" content="#FFD700">
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  :root {
    --oro:#FFD700; --oro-light:#FDF8F0; --oro-medium:#E6B800;
    --cielo:#87CEEB; --cielo-light:#E8F4FF;
    --bianco:#fff; --text:#1F2937; --text-light:#6B7280;
    --serif: Georgia, 'Times New Roman', 'Noto Serif', serif;
    --sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  body {
    font-family: var(--sans);
    background: var(--bianco); color: var(--text); line-height:1.6; font-size:16px;
    -webkit-tap-highlight-color:transparent;
  }
  .screen { display:none; }
  .screen.active { display:block; }
  #s3.active { display:flex; flex-direction:column; height:100dvh; height:100vh; }
  #s1.active { display:flex; }

  /* HOME */
  #s1 {
    position:relative; padding:24px 20px; max-width:600px; margin:0 auto;
    min-height:100dvh; min-height:100vh; flex-direction:column; justify-content:center;
    align-items:center; text-align:center; overflow:hidden;
  }
  .mini-hearts { position:absolute; inset:0; pointer-events:none; overflow:hidden; z-index:0; }
  .mini-hearts span {
    position:absolute; bottom:10%; font-size:1.6rem; opacity:0;
    animation: floatUp 8s ease-in infinite;
  }
  .mini-hearts span:nth-child(1) { left:15%; animation-delay:0s; }
  .mini-hearts span:nth-child(2) { left:48%; animation-delay:2.5s; font-size:1.3rem; }
  .mini-hearts span:nth-child(3) { left:78%; animation-delay:5s; font-size:1.9rem; }
  @keyframes floatUp {
    0%   { transform:translateY(0) scale(0.7); opacity:0; }
    20%  { opacity:0.85; }
    80%  { opacity:0.6; }
    100% { transform:translateY(-55vh) scale(1.1); opacity:0; }
  }
  #s1 .hero, #s1 .btn-start, #s1 .privacy-note, #s1 .consenso-box, #s1 .link-principi { position:relative; z-index:1; }

  .hero-symbols { margin-top:28px; font-size:1.4rem; letter-spacing:0.6rem; opacity:0.85; }
  @media (prefers-reduced-motion: reduce) {
    .mini-hearts span, .hero h1 .heart { animation:none; }
  }

  .hero { margin-bottom:24px; }
  .hero h1 { font-size:3rem; margin-bottom:16px; font-weight:800; letter-spacing:0.5px; }
  .hero h1 .heart { display:inline-block; animation:heartbeat 1.4s ease-in-out infinite; transform-origin:center; }
  @keyframes heartbeat {
    0%,100% { transform:scale(1); } 15% { transform:scale(1.25); } 30% { transform:scale(1); }
    45% { transform:scale(1.15); } 60% { transform:scale(1); }
  }
  .hero h1 .perte-text {
    background:linear-gradient(135deg, var(--oro) 0%, #B8860B 100%);
    -webkit-background-clip:text; background-clip:text;
    -webkit-text-fill-color:transparent; color:var(--oro);
  }
  .hero p { font-size:1.35rem; color:var(--text); font-weight:600; line-height:1.5; max-width:420px; }

  .consenso-box {
    width:100%; max-width:380px; margin:0 auto 16px;
    background:var(--oro-light); border:1px solid var(--oro);
    border-radius:12px; padding:14px; text-align:left; font-size:0.88rem;
  }
  .consenso-box label { display:flex; gap:8px; align-items:flex-start; cursor:pointer; margin-bottom:10px; }
  .consenso-box label:last-child { margin-bottom:0; }
  .consenso-box input { margin-top:3px; }
  .consenso-box a, .privacy-note a, .link-principi a { color:#3a7ca5; }

  .link-principi { margin-bottom:14px; font-size:0.9rem; }

  .btn-start {
    width:100%; max-width:360px; padding:20px;
    background:linear-gradient(135deg, var(--oro) 0%, var(--oro-medium) 100%);
    color:var(--text); border:none; border-radius:16px;
    font-size:1.2rem; font-weight:700; cursor:pointer;
    transition:all 0.25s ease; box-shadow:0 4px 16px rgba(255,215,0,0.35);
  }
  .btn-start:disabled { opacity:0.5; cursor:not-allowed; }
  .btn-start:hover:not(:disabled) { transform:translateY(-2px); }
  .btn-start:active:not(:disabled) { transform:scale(0.97); }

  .privacy-note { margin-top:36px; font-size:0.72rem; font-weight:500; color:var(--text-light); max-width:380px; opacity:0.85; }

  /* CHAT */
  .header-back { display:flex; align-items:center; margin-bottom:16px; gap:12px; }
  .header-back button {
    background:var(--oro-light); border:none; font-size:1.4rem; cursor:pointer; color:var(--text);
    width:42px; height:42px; border-radius:10px;
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
  }
  .header-back button:active { transform:scale(0.92); background:var(--oro); }

  #s3 { padding:16px; max-width:600px; margin:0 auto; }
  .msgs { flex:1; overflow-y:auto; margin-bottom:16px; display:flex; flex-direction:column; gap:12px; }
  .row { display:flex; margin-bottom:8px; }
  .row.user { justify-content:flex-end; }
  .bub {
    max-width:85%; padding:12px 16px; border-radius:16px;
    font-size:0.95rem; line-height:1.5; white-space:pre-wrap; word-break:break-word;
    position:relative;
  }
  .bub.user { background:var(--oro); color:var(--text); border-radius:16px 4px 16px 16px; }
  .bub.bot { background:#F3F4F6; color:var(--text); border-radius:4px 16px 16px 16px; }
  .bub .edit-hint {
    position:absolute; bottom:-2px; right:8px; font-size:0.65rem;
    color:rgba(0,0,0,0.4); cursor:pointer; opacity:0; transition:opacity 0.2s;
  }
  .bub.user:hover .edit-hint, .bub.bot:hover .edit-hint { opacity:1; }

  .lang-select { display:flex; gap:6px; margin-bottom:8px; flex-wrap:wrap; }
  .lang-select button {
    background:var(--oro-light); border:1px solid var(--oro); color:var(--text);
    padding:4px 10px; border-radius:6px; font-size:0.75rem; cursor:pointer;
  }
  .lang-select button.active { background:var(--oro); font-weight:600; }

  .inputbar { display:flex; gap:8px; align-items:flex-end; }
  #inp {
    flex:1; padding:12px; border:2px solid var(--oro-light); border-radius:8px;
    font-size:1rem; font-family:inherit; resize:none; max-height:100px;
  }
  #inp:focus { outline:none; border-color:var(--oro); box-shadow:0 0 0 2px var(--oro-light); }
  .btn-mic, .btn-send, .btn-finish {
    border:none; border-radius:12px; cursor:pointer; font-size:1.2rem;
    display:flex; align-items:center; justify-content:center;
    transition:all 0.2s ease; flex-shrink:0;
  }
  .btn-mic, .btn-send {
    width:46px; height:46px;
    background:linear-gradient(135deg, var(--oro) 0%, var(--oro-medium) 100%);
    color:var(--text); box-shadow:0 3px 10px rgba(255,215,0,0.3);
  }
  .btn-finish {
    padding:0 14px; height:46px; font-size:0.85rem; font-weight:700;
    background:linear-gradient(135deg, var(--cielo) 0%, #5BA8C5 100%); color:#fff;
  }
  .btn-mic:active, .btn-send:active, .btn-finish:active { transform:scale(0.92); }
  .btn-mic.recording { background:#E5383B; color:#fff; }
  .btn-send:disabled { opacity:0.5; cursor:not-allowed; }
  .btn-finish:disabled { opacity:0.4; cursor:not-allowed; }

  .pause-buttons {
    display:flex; gap:8px; margin:8px 0;
  }
  .pause-buttons .btn { flex:1; }

  /* RISULTATO */
  #s4 { padding:20px; max-width:600px; margin:0 auto; }

  .result-mode-selector {
    display:flex; gap:8px; margin-bottom:16px; justify-content:center;
  }
  .result-mode-selector button {
    flex:1; max-width:180px; padding:10px; border:1px solid var(--oro);
    background:var(--bianco); color:var(--text); border-radius:10px;
    font-size:0.9rem; font-weight:600; cursor:pointer; transition:all 0.2s ease;
  }
  .result-mode-selector button.active {
    background:linear-gradient(135deg, var(--oro) 0%, var(--oro-medium) 100%);
    box-shadow:0 3px 10px rgba(255,215,0,0.3);
  }

  .result-box {
    background:var(--oro-light); border:3px solid var(--oro);
    border-radius:16px; padding:32px 24px; margin-bottom:24px;
    box-shadow:0 4px 24px rgba(255,215,0,0.15);
    animation: comparsa 0.8s ease-out;
  }
  @keyframes comparsa {
    0% { opacity:0; transform:translateY(12px); }
    100% { opacity:1; transform:translateY(0); }
  }
  .result-box.cielo { background:var(--cielo-light); border-color:var(--cielo); }
  .result-title {
    font-size:1.1rem; font-weight:700; color:#B8860B; margin-bottom:20px;
    text-align:center; letter-spacing:0.5px;
  }
  .result-box.cielo .result-title { color:#3a7ca5; }

  .result-text-display {
    font-family:var(--serif); font-size:1.15rem; line-height:2;
    color:var(--text); white-space:pre-wrap; word-break:break-word;
    margin-bottom:0;
  }

  .result-edit {
    width:100%; min-height:240px; padding:16px; border:2px solid var(--oro);
    border-radius:8px; font-family:var(--serif); font-size:1.15rem; line-height:2;
    background:#fff; color:var(--text); resize:vertical;
  }
  .result-edit:focus { outline:none; border-color:#B8860B; }

  .result-actions-inline {
    display:flex; gap:14px; justify-content:flex-end; margin-top:14px;
    font-size:0.85rem;
  }
  .result-actions-inline button {
    background:none; border:none; color:#3a7ca5; cursor:pointer;
    text-decoration:underline; padding:4px;
  }
  .result-actions-inline button:hover { color:#1e5278; }

  .edit-note { font-size:0.78rem; color:var(--text-light); margin-top:8px; font-style:italic; }

  .share-buttons { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:24px; }
  .btn {
    padding:14px 10px; border:none; border-radius:12px; font-size:0.92rem;
    font-weight:700; cursor:pointer; transition:all 0.2s ease; min-height:48px;
  }
  .btn-oro {
    background:linear-gradient(135deg, var(--oro) 0%, var(--oro-medium) 100%);
    color:var(--text); box-shadow:0 3px 10px rgba(255,215,0,0.3);
  }
  .btn-primary {
    background:linear-gradient(135deg, #B8860B 0%, #8B6914 100%);
    color:#fff; box-shadow:0 4px 14px rgba(184,134,11,0.4); font-size:1rem;
  }
  .btn-secondary { background:#F3F4F6; color:var(--text); }
  .btn:active { transform:scale(0.96); }

  .typing { display:none; }
  .typing.on { display:flex; gap:4px; align-items:center; padding:8px 12px; background:#F3F4F6; border-radius:16px; width:fit-content; }
  .typing span { width:6px; height:6px; background:var(--text-light); border-radius:50%; animation:blink 1.4s infinite; }
  .typing span:nth-child(2) { animation-delay:0.2s; }
  .typing span:nth-child(3) { animation-delay:0.4s; }
  @keyframes blink { 0%,60%,100% { opacity:0.3; } 30% { opacity:1; } }

  .error-inline {
    background:#FFF4F4; border:1px solid #F5C2C2; color:#8B2E2E;
    padding:10px 14px; border-radius:10px; font-size:0.9rem; margin-bottom:8px;
  }
  .crisis-banner {
    background:#FFF4F4; border:2px solid #E5383B; color:#8B2E2E;
    padding:14px; border-radius:12px; font-size:0.92rem; margin-bottom:12px; line-height:1.6;
  }
  .crisis-banner strong { display:block; margin-bottom:6px; }
  .turn-counter { font-size:0.75rem; color:var(--text-light); text-align:center; margin-bottom:6px; }

  /* MODALI */
  .modal-overlay {
    display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6);
    z-index:100; padding:20px; overflow-y:auto;
  }
  .modal-overlay.show { display:block; }
  .modal-box {
    background:#fff; max-width:520px; margin:30px auto; border-radius:16px; padding:28px;
  }
  .modal-box h2 { margin-bottom:18px; font-size:1.4rem; }
  .modal-box p, .modal-box li { font-size:0.92rem; line-height:1.8; }
  .modal-box .principio { margin-bottom:14px; }
  .modal-box .principio strong { display:block; color:#B8860B; margin-bottom:4px; }

  .provenienza-box {
    background:var(--oro-light); border-left:4px solid var(--oro);
    padding:14px 16px; margin:10px 0; border-radius:6px;
    font-size:0.9rem; line-height:1.7;
  }
  .provenienza-box .source { font-style:italic; color:var(--text-light); }

  @media (max-width:380px) {
    .hero h1 { font-size:2.5rem; }
    .hero p { font-size:1.15rem; }
    .btn-start { font-size:1.05rem; padding:18px; }
    .result-text-display, .result-edit { font-size:1.05rem; }
    .mini-hearts span { font-size:2rem; }
    .mini-hearts span:nth-child(2) { font-size:1.6rem; }
    .mini-hearts span:nth-child(3) { font-size:2.3rem; }
  }
</style>
</head>
<body>

<!-- HOME -->
<div class="screen active" id="s1">
  <div class="mini-hearts"><span>❤️</span><span>❤️</span><span>❤️</span></div>

  <div class="lang-select" id="langSelectHome" style="justify-content:center; margin-bottom:18px;">
    <button data-lang="it-IT" class="active">🇮🇹 IT</button>
    <button data-lang="en-US">🇬🇧 EN</button>
    <button data-lang="es-ES">🇪🇸 ES</button>
    <button data-lang="fr-FR">🇫🇷 FR</button>
    <button data-lang="ru-RU">🇷🇺 RU</button>
    <button data-lang="pt-PT">🇵🇹 PT</button>
    <button data-lang="de-DE">🇩🇪 DE</button>
    <button data-lang="ro-RO">🇷🇴 RO</button>
  </div>

  <div class="hero">
    <h1><span class="heart">❤️</span> <span class="perte-text">PerTe</span></h1>
    <p id="t_heroP1">Raccontami quello che senti.</p>
    <p style="font-size:1.1rem; font-weight:500; color:#6B7280; margin-top:18px; line-height:1.7;" id="t_heroP2">
      Di chi ami, di chi ti manca.<br>
      Chi c'è ancora, chi porti nel cuore.<br>
      Anche se non lo vedi da tanto.
    </p>
    <p style="font-size:1.1rem; font-weight:500; color:#6B7280; margin-top:14px;" id="t_heroP3">
      Non serve trovare le parole.<br>Le troviamo insieme.
    </p>
    <div class="hero-symbols" aria-hidden="true">🤍 🐾 🕊️</div>
  </div>

  <div class="consenso-box">
    <label>
      <input type="checkbox" id="consensoEta">
      <span id="t_consensoEta">Dichiaro di avere almeno 16 anni.</span>
    </label>
    <label>
      <input type="checkbox" id="consenso">
      <span><span id="t_consensoTesto">Acconsento a condividere il mio racconto (anonimizzato) con PerTe per migliorare il servizio.</span> <a href="#privacy" onclick="apriPrivacy();return false;" id="t_linkPrivacy">Informativa privacy</a>.</span>
    </label>
  </div>

  <button class="btn-start" id="btnStart" onclick="iniziaRacconto()" disabled>Raccontami</button>

  <div class="link-principi" style="font-size:0.75rem; opacity:0.75; margin-top:18px;">
    <a href="#principi" onclick="apriPrincipi();return false;" id="t_linkPrincipi">📜 I principi di PerTe</a>
  </div>

  <div class="privacy-note" id="t_privacyNote">
    🔒 Non scrivere dati personali (telefono, email, indirizzi).
  </div>
</div>

<!-- CHAT -->
<div class="screen" id="s3">
  <div class="header-back" style="justify-content:space-between;">
    <button onclick="back()" aria-label="Torna all'inizio">←</button>
    <span style="font-size:1.2rem; font-weight:800;"><span class="heart">❤️</span> <span class="perte-text">PerTe</span></span>
    <button onclick="eliminaConversazione()" aria-label="Ricomincia">🗑️</button>
  </div>
  <div class="crisis-banner" id="crisis" style="display:none;">
    <strong id="t_crisisTitle">Se stai male ora:</strong>
    <span id="t_crisisLine1">Telefono Amico Italia</span>: <a href="tel:0223272327">02 2327 2327</a> <span id="t_crisisHours">(tutti i giorni 10–24)</span><br>
    <span id="t_crisisEmergency">Emergenze</span>: <a href="tel:112">112</a>
  </div>
  <div class="turn-counter" id="turnCounter"></div>
  <div class="msgs" id="msgs" aria-live="polite"></div>
  <div class="typing" id="typing"><span></span><span></span><span></span></div>
  <div class="inputbar">
    <textarea id="inp" rows="1" placeholder="Scrivi o parla…" maxlength="2000"></textarea>
    <button class="btn-mic" id="mic" aria-label="Microfono" onclick="toggleMic()">🎙️</button>
    <button class="btn-finish" id="finish" onclick="forzaLettera()" disabled><span id="t_btnFinish">Scrivi ✍️</span></button>
    <button class="btn-send" id="send" onclick="send()" disabled>→</button>
  </div>
</div>

<!-- RISULTATO -->
<div class="screen" id="s4">
  <div class="header-back">
    <button onclick="back()" aria-label="Indietro">←</button>
    <h2 id="t_resultHeader">Il tuo ricordo</h2>
  </div>

  <div class="result-mode-selector">
    <button id="modeLettera" class="active" onclick="cambiaModalita('lettera')">✉️ Lettera</button>
    <button id="modeRacconto" onclick="cambiaModalita('racconto')">📖 Racconto</button>
  </div>

  <div class="result-box" id="resultBox">
    <div class="result-title" id="t_resultTitle">❤️ Parole per ricordare</div>
    <div id="resultView">
      <div class="result-text-display" id="resbodyView"></div>
      <div class="result-actions-inline">
        <button onclick="toggleProvenienza()" id="t_whyBtn">❓ Perché questa frase?</button>
        <button onclick="toggleEdit()" id="t_editBtn">✏️ Modifica</button>
      </div>
      <div id="provenienzaBox" style="display:none; margin-top:14px;"></div>
    </div>
    <div id="resultEdit" style="display:none;">
      <textarea class="result-edit" id="resbodyEdit"></textarea>
      <div class="edit-note" id="t_editNote">✏️ Puoi modificare il testo direttamente qui sopra. Quando hai finito, copia o salva.</div>
    </div>
  </div>

  <div class="share-buttons">
    <button class="btn btn-primary" onclick="scaricaTesto()" id="t_saveBtn">💾 Salva il ricordo</button>
    <button class="btn btn-oro" onclick="copyResult()" id="t_copyBtn">📋 Copia</button>
    <button class="btn btn-oro" onclick="shareWhatsApp()" id="t_whatsappBtn">💬 WhatsApp</button>
    <button class="btn btn-secondary" onclick="newRacconto()" id="t_anotherBtn">+ Un Altro</button>
  </div>
</div>

<!-- MODAL PRINCIPI -->
<div class="modal-overlay" id="principiModal">
  <div class="modal-box">
    <h2 id="t_principiTitle">📜 I principi di PerTe</h2>
    <p style="margin-bottom:18px;" id="t_principiIntro">PerTe è uno spazio di <strong>custodia</strong> dei ricordi. Non creiamo storie: le accogliamo, le rispettiamo, le restituiamo. Questi sono i nostri impegni verso di te:</p>

    <div class="principio" id="t_principio1">
      <strong>1. La storia appartiene a te.</strong>
      Non inventiamo eventi, persone o dettagli che non emergono dal tuo racconto. Se un'informazione non c'è, non la mettiamo.
    </div>

    <div class="principio" id="t_principio2">
      <strong>2. Meglio omettere che inventare.</strong>
      Quando non abbiamo abbastanza elementi per un'affermazione, preferiamo il silenzio all'invenzione. Una lettera breve e vera vale più di una lettera lunga e falsa.
    </div>

    <div class="principio" id="t_principio3">
      <strong>3. Il significato non cambia.</strong>
      Se il tuo ricordo era gioia, resta gioia. Se era gratitudine, resta gratitudine. Non trasformiamo il senso di ciò che hai provato.
    </div>

    <div class="principio" id="t_principio4">
      <strong>4. Cerchiamo di rispettare il tuo modo di raccontare.</strong>
      Se parli semplice, la lettera sarà semplice. Se hai ironia, proviamo a conservarla. Non sempre ci riusciamo: se una frase non ti suona tua, puoi cancellarla o dircelo, e la rifacciamo.
    </div>

    <div class="principio" id="t_principio5">
      <strong>5. La forma può cambiare, il significato no.</strong>
      Possiamo riordinare, collegare, togliere ripetizioni. Ma non cambiamo il cuore di ciò che hai detto.
    </div>

    <div class="principio" id="t_principio6">
      <strong>6. Niente parole da macchina.</strong>
      Il testo non conterrà mai termini come "AI", "generato", "elaborato". Deve sembrare scritto da un cuore umano, perché dà voce al tuo.
    </div>

    <div class="principio" id="t_principio7">
      <strong>7. Puoi sempre verificare.</strong>
      Con il pulsante "Perché questa frase?" puoi vedere quali tue parole hanno ispirato ogni passaggio. La trasparenza viene prima della poesia.
    </div>

    <div class="principio" id="t_principio8">
      <strong>8. Onestà sull'imperfezione.</strong>
      Non promettiamo la perfezione. Ogni scrittura è un'interpretazione. Se una frase non ti convince, puoi modificarla, cancellarla o chiederci di riprovarci. La tua parola finale viene sempre prima della nostra.
    </div>

    <button class="btn btn-oro" onclick="chiudiPrincipi()" style="width:100%; margin-top:8px;" id="t_principiOk">Ho capito</button>
  </div>
</div>

<!-- MODAL PRIVACY -->
<div class="modal-overlay" id="privacyModal">
  <div class="modal-box">
    <h2 id="t_privacyTitle">Informativa Privacy</h2>
    <p style="margin-bottom:12px;" id="t_privacyIntro"><strong>PerTe</strong> è uno spazio di ascolto. Ecco come trattiamo i tuoi dati:</p>
    <ul style="font-size:0.92rem; line-height:1.7; padding-left:20px; margin-bottom:16px;" id="t_privacyList">
      <li>Il racconto viene inviato al servizio AI per generare il testo finale.</li>
      <li>Se hai dato il consenso, racconto e testo vengono salvati <strong>anonimizzati</strong> per migliorare il servizio.</li>
      <li>Non salviamo nome, email, telefono o altri dati identificativi.</li>
      <li>Le conversazioni in corso sono salvate solo nel tuo browser (localStorage) per non perderle se chiudi la pagina.</li>
      <li>Puoi ritirare il consenso quando vuoi, semplicemente cancellando la conversazione o uscendo dall'app.</li>
      <li>Titolare del trattamento: PerTe. Diritti GDPR art. 15–17.</li>
    </ul>
    <button class="btn btn-oro" onclick="chiudiPrivacy()" style="width:100%;" id="t_privacyOk">Ho capito</button>
  </div>
</div>

<script>
let hist = [], racconto_id = '';
let isRecording = false, recognition = null;
let micBase = '', micFinal = '';
let isCalling = false;
let scambi = 0;
let contatoreIdentita = 0;
let currentLang = 'it-IT';
const MAX_SCAMBI = 6;
const STORAGE_KEY = 'perte_session';
const LOG_KEY = 'perte_log';
const MAX_LOG_ENTRIES = 10;
let modalitaCorrente = 'lettera';
let ultimaLettera = '';
let ultimaProvenienza = [];

// === CONSensi ===
function checkConsensi() {
  const eta = document.getElementById('consensoEta').checked;
  const consenso = document.getElementById('consenso').checked;
  document.getElementById('btnStart').disabled = !(eta && consenso);
}
document.getElementById('consensoEta').addEventListener('change', checkConsensi);
document.getElementById('consenso').addEventListener('change', checkConsensi);

function apriPrivacy() { document.getElementById('privacyModal').classList.add('show'); }
function chiudiPrivacy() { document.getElementById('privacyModal').classList.remove('show'); }
function apriPrincipi() { document.getElementById('principiModal').classList.add('show'); }
function chiudiPrincipi() { document.getElementById('principiModal').classList.remove('show'); }

// === TRADUZIONI COMPLETE (HOME, CHAT, MODALI, MESSAGGI) ===
const TRADUZIONI = {
  'it-IT': {
    heroP1: 'Raccontami quello che senti.',
